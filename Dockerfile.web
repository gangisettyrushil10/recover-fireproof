# syntax=docker/dockerfile:1.7
# Multi-stage build for @fireproof/web (Next.js 15 standalone output).
# Requires apps/web/next.config.* to set `output: 'standalone'`.

ARG NODE_VERSION=20-alpine
ARG PNPM_VERSION=9.12.0

# ---------- Stage 1: deps ----------
FROM node:${NODE_VERSION} AS deps
ARG PNPM_VERSION
RUN apk add --no-cache libc6-compat \
    && corepack enable \
    && corepack prepare pnpm@${PNPM_VERSION} --activate
WORKDIR /repo

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json .npmrc* ./
RUN pnpm fetch

# ---------- Stage 2: build ----------
FROM node:${NODE_VERSION} AS build
ARG PNPM_VERSION
ENV NEXT_TELEMETRY_DISABLED=1
RUN apk add --no-cache libc6-compat \
    && corepack enable \
    && corepack prepare pnpm@${PNPM_VERSION} --activate
WORKDIR /repo

COPY --from=deps /repo /repo
COPY . .

RUN pnpm install --frozen-lockfile --offline
RUN pnpm --filter @fireproof/web... build

# ---------- Stage 3: runtime ----------
FROM node:${NODE_VERSION} AS runtime
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0
WORKDIR /app

RUN addgroup -S app && adduser -S app -G app

# Next.js standalone output places a self-contained server under .next/standalone
# and static assets under .next/static. The standalone tree mirrors the monorepo
# layout, so the entrypoint lives at apps/web/server.js.
COPY --from=build --chown=app:app /repo/apps/web/.next/standalone ./
COPY --from=build --chown=app:app /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=app:app /repo/apps/web/public ./apps/web/public

USER app
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
