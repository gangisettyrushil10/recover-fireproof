{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm --filter @fireproof/web build",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "apps/web/app/api/v1/**": {
      "maxDuration": 60
    }
  }
}
