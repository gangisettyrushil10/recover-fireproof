{
  "name": "@fireproof/db",
  "version": "0.1.0",
  "private": true,
  "description": "Fireproof Drizzle schema, migrations, and Postgres connection helpers.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts"
    },
    "./migrations": {
      "types": "./src/migrations.ts",
      "import": "./src/migrations.ts"
    }
  },
  "files": ["src", "migrations"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:push": "drizzle-kit push",
    "test": "vitest run"
  },
  "dependencies": {
    "@fireproof/domain": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
