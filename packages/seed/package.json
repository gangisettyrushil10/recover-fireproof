{
  "name": "@fireproof/seed",
  "version": "0.1.0",
  "private": true,
  "description": "Cedar Heights canonical demo seed for Fireproof.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src", "assets"],
  "scripts": {
    "seed": "tsx src/index.ts",
    "seed:reset": "tsx src/index.ts --reset",
    "seed:check": "tsx src/check.ts",
    "seed:post-fire": "tsx src/index.ts --post-fire",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@fireproof/db": "workspace:*",
    "@fireproof/domain": "workspace:*",
    "@fireproof/rules": "workspace:*",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
