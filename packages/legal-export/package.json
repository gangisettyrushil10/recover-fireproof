{
  "name": "@fireproof/legal-export",
  "version": "0.1.0",
  "private": true,
  "description": "Pure-logic library for Fireproof contradiction detection and packet bundle generation.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./claims": "./src/claims/extractor.ts",
    "./contradictions": "./src/contradictions/engine.ts",
    "./packets": "./src/packets/index.ts",
    "./holds": "./src/holds/policy.ts",
    "./audit": "./src/audit/chain.ts",
    "./types": "./src/types.ts"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fireproof/domain": "workspace:*",
    "archiver": "^7.0.1",
    "date-fns": "^3.6.0",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
