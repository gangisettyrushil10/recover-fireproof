{
  "name": "@fireproof/rules",
  "version": "0.1.0",
  "private": true,
  "description": "Rule pack engine and seeded jurisdiction packs for Fireproof.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./evaluator": "./src/evaluator.ts",
    "./packs": "./src/packs/index.ts",
    "./types": "./src/types.ts"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fireproof/domain": "workspace:*",
    "date-fns": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
