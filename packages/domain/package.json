{
  "name": "@fireproof/domain",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain types, Zod schemas, enums, state machines, and error codes for Fireproof.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas/index.ts",
    "./enums": "./src/enums.ts",
    "./errors": "./src/errors.ts",
    "./states": "./src/states.ts",
    "./transitions": "./src/transitions.ts",
    "./api": "./src/api/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test": "echo \"(no tests yet)\" && exit 0"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.2"
  }
}
