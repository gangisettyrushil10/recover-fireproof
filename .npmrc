# Hoist workspace deps to the root node_modules so Next.js's webpack can
# resolve them when the route-handler stack in apps/web imports from
# @fireproof/api, which in turn imports @fireproof/legal-export etc.
# Without this, webpack from apps/web only walks its own node_modules
# and misses transitive workspace deps that pnpm symlinks into apps/api.
public-hoist-pattern[]=@fireproof/*
public-hoist-pattern[]=drizzle-orm
public-hoist-pattern[]=pg
public-hoist-pattern[]=pdf-lib
public-hoist-pattern[]=archiver
public-hoist-pattern[]=jose
public-hoist-pattern[]=zod
