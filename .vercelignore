# Vercel deploys the Next.js app at apps/web. The colocated route handlers
# under apps/web/app/api/v1/** import services from @fireproof/api via the
# workspace, so apps/api MUST be included.

# Worker app — not deployed via Vercel
apps/worker

# Infrastructure that lives outside the Vercel build
infrastructure
docker-compose.yml
Dockerfile.api
Dockerfile.web
Dockerfile.worker
.github

# Local content-addressed storage (dev WORM adapter)
.storage

# Test/coverage/build caches
**/.turbo
**/coverage
**/dist
**/.next
**/node_modules

# Editor / OS noise
.DS_Store
.idea
.vscode
*.log

# Env files (Vercel uses its own env settings)
.env
.env.*
!.env.example
