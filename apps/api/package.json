{
  "name": "@fireproof/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fireproof Fastify REST API — exception ops system of record.",
  "type": "module",
  "main": "./src/server.ts",
  "exports": {
    "./services/audit": "./src/services/AuditEventService.ts",
    "./services/evidence": "./src/services/EvidenceValidationService.ts",
    "./services/legal-holds": "./src/services/LegalHoldService.ts",
    "./services/documents": "./src/services/DocumentService.ts",
    "./services/exceptions": "./src/services/ExceptionLifecycleService.ts",
    "./services/rules": "./src/services/RuleEvaluationService.ts",
    "./services/packets": "./src/services/PacketService.ts",
    "./services/dashboard": "./src/services/PropertyDashboardService.ts",
    "./storage": "./src/storage/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo .storage",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@fireproof/db": "workspace:*",
    "@fireproof/domain": "workspace:*",
    "@fireproof/legal-export": "workspace:*",
    "@fireproof/rules": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "tsx": "^4.19.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
